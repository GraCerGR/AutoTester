FROM debian:bookworm-slim
USER root

WORKDIR /tmp
COPY dockerfiles/java/pom.xml /tmp/pom.xml

# Java + Maven
RUN apt-get update && \
    apt-get install -y openjdk-17-jdk maven git && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash seluser

WORKDIR /app

RUN mkdir -p /app && chown -R seluser:seluser /app
USER seluser

WORKDIR /home/seluser

COPY --chown=seluser:seluser dockerfiles/java/pom.xml ./pom.xml
RUN mvn -B dependency:go-offline

WORKDIR /app

CMD ["sleep", "infinity"]
